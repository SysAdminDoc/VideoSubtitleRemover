#: gui/app.py:2126
msgid "Auto-detect the subtitle language from a sample frame."
msgstr ""

#: gui/app.py:2143
msgid "Skip repeated detection when you have already set a precise subtitle region."
msgstr ""

#: gui/app.py:2151
msgid "LaMa fast mode is useful for quick passes and lower-resolution drafts."
msgstr ""

#: gui/app.py:2254
msgid "Scale mask dilation inversely with OCR confidence: low-confidence boxes get more padding, high-confidence boxes stay tight."
msgstr ""

#: gui/app.py:2270
msgid "Scan the first 30 frames and pin the dominant subtitle band before processing."
msgstr ""

#: gui/app.py:2279
msgid "Farneback optical flow aligns frames before TBE aggregation. Slower but cleaner on pans and zooms."
msgstr ""

#: gui/app.py:2288
msgid "Prevents background aggregation across hard cuts. Turn off if your footage is uncut."
msgstr ""

#: gui/app.py:2297
msgid "Smooths per-frame OCR jitter and fills single-frame misses. Recommended."
msgstr ""

#: gui/app.py:2306
msgid "Skip OCR on frames nearly identical to the last detected one. Speeds up long static shots."
msgstr ""

#: gui/app.py:2315
msgid "Grow the mask to cover serifs / drop shadows that match the subtitle colour. Catches decorative lettering."
msgstr ""

#: gui/app.py:2325
msgid "Rotates each frame 90 CCW before OCR so columnar CJK reads as a line. Boxes rotate back to the source frame."
msgstr ""

#: gui/app.py:2345
msgid "If hardware encoding fails the app retries automatically with libx264."
msgstr ""

#: gui/app.py:2360
msgid "h264 is universal; h265 and av1 cut bitrate ~50% on 4K; vvc (H.266) needs FFmpeg with libvvenc. Uses NVENC/QSV/AMF when available."
msgstr ""

#: gui/app.py:2369
msgid "Scale the TBE window to fit free VRAM. Prevents OOM on 4K, unlocks headroom on 24 GB cards."
msgstr ""

#: gui/app.py:2378
msgid "Writes an .srt file next to the output using OCR text and timings."
msgstr ""

#: gui/app.py:2387
msgid "Writes a black-and-white mp4 of the per-frame detection mask alongside the output."
msgstr ""

#: gui/app.py:2396
msgid "ffprobe-checks the input for combing; runs ffmpeg yadif if detected."
msgstr ""

#: gui/app.py:2405
msgid "Large speedup for long videos. Falls back to pHash skip if ffprobe is missing."
msgstr ""

#: gui/app.py:2414
msgid "Samples 10 random frames, compares input vs output; logged and shown in the batch summary."
msgstr ""

#: gui/app.py:2466
msgid "Tracks the chyron classifier marks as dialogue subtitles."
msgstr ""

#: gui/app.py:2475
msgid "Kalman tracks lasting longer than ~3s are treated as chyrons."
msgstr ""

#: gui/app.py:2484
msgid "Stops karaoke captions leaking original text through the gaps between syllables."
msgstr ""

#: gui/app.py:2498
msgid "Mux every audio stream from the source. Off keeps only the first track."
msgstr ""

#: gui/app.py:2535
msgid "Hint for cv2.VideoCapture. Falls back to software if the HW path returns no frames."
msgstr ""

#: gui/app.py:2553
msgid "0 disables. Values above 1 inpaint keyframes and synthesize skipped frames with Practical-RIFE when installed."
msgstr ""

#: gui/app.py:2562
msgid "Decouples cv2.VideoCapture.read() from the detect+inpaint critical path. On by default."
msgstr ""

#: gui/app.py:2573
msgid "Renders <output>.qualitysheet.png with per-sample PSNR/SSIM. Implies the numeric report."
msgstr ""

#: gui/app.py:2582
msgid "Write a structured JSON-lines log alongside the text log. Useful for long batch runs and scripted post-processing."
msgstr ""

#: gui/app.py:2594
msgid "Alternative palette tuned for low-vision users. Persists across sessions."
msgstr ""

#: gui/app.py:2603
msgid "When enabled, checks GitHub Releases for a newer version on launch. Off by default; no telemetry."
msgstr ""

